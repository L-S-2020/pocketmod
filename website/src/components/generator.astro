const allIdeas = [...ideas];
let isTyping = false;

function getNextIdea() {
  if (ideas.length === 0) {
    ideas.push(...allIdeas);
  }

  const randomIndex = Math.floor(Math.random() * ideas.length);
  return ideas.splice(randomIndex, 1)[0];
}

function typeText(element, text, caret) {
  if (!element || !caret) return;

  isTyping = true;
  element.textContent = "";
  element.appendChild(caret);

  let index = 0;
  const typeInterval = setInterval(() => {
    if (index >= text.length) {
      clearInterval(typeInterval);
      isTyping = false;
      return;
    }

    const nextChar = document.createTextNode(text[index]);
    element.insertBefore(nextChar, caret);
    index += 1;
  }, 22);
}

document.addEventListener("DOMContentLoaded", () => {
  const button = document.getElementById("generate-idea-btn");
  const output = document.getElementById("idea-output");
  const caret = document.getElementById("idea-caret");

  if (!button || !output || !caret) return;

  button.addEventListener("click", () => {
    if (isTyping) return;
    const nextIdea = getNextIdea();
    typeText(output, nextIdea, caret);
  });
});
</script>