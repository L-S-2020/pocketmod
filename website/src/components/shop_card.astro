---
import { Image } from "astro:assets";
import sticksvg from "../assets/stick.svg";
const { title, description, image, price } = Astro.props;
---

<div class="group bg-zinc-100 rounded-3xl overflow-hidden shadow-lg hover:shadow-xl hover:scale-[1.02] transition-all cursor-pointer flex flex-col">

  <!-- Image -->
  <div class="overflow-hidden border-b-2 border-zinc-200">
    {image
      ? <Image src={image} alt={title} width={400} height={255} class="w-full h-48 object-contain group-hover:scale-105 transition-transform duration-500" />
      : <div class="w-full h-48 flex items-center justify-center text-zinc-400 text-sm">no image</div>
    }
  </div>

  <!-- Info -->
  <div class="p-6 flex flex-col gap-3 flex-1">
    <div class="flex-1">
      <h2 class="text-xl font-bold mb-2">{title}</h2>
      <p class="text-gray-400 text-sm">{description}</p>
    </div>

    <div class="flex items-center justify-between gap-3 mt-auto pt-3 border-t border-zinc-100">
      <!-- Price in sticks -->
      <div class="flex items-baseline gap-1 mt-auto">
        <span class="text-2xl font-black text-zinc-900">{price}</span>
        <Image src={sticksvg} alt="Stick icon" width={50} height={50} class="w-5 h-5" />
      </div>
    </div>
  </div>

</div>
