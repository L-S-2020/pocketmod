---
import { Image } from "astro:assets";
import logosvg from "../assets/logo.svg";
import pcbdesign from "../assets/pcb_design.png";
import timetracking from "../assets/timetracking.png";
import grantcard from "../assets/grantcard.png";
import prizesimg from "../assets/prizesimg.png";
import "../styles/global.css";
import Generator from "../components/generator.astro";
import GalleryCard from "../components/gallery_card.astro";
import ProjectPopup from "../components/project_popup.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Pocketmod | YSWS Draft</title>
    <script is:inline src="https://cdn.jsdelivr.net/npm/@mux/mux-player" defer></script>
    <script is:inline src="https://server.fillout.com/embed/v1/" defer></script>
  </head>

  <body class="bg-white text-zinc-900 overflow-x-hidden">

    <!-- Hack Club Flag -->
    <a href="https://hackclub.com/" class="fixed top-0 left-5 z-50">
      <img src="https://assets.hackclub.com/flag-orpheus-top-bw.svg" alt="Hack Club" class="w-36" />
    </a>

    <!-- ═══════════════════════════════════════════════════ HERO -->
	<section id="hero-section" class="min-h-screen bg-white flex flex-col items-center justify-center text-center px-6 relative overflow-hidden">
	  <!-- Grid background: static black lines -->
	<div class="absolute inset-0 bg-[linear-gradient(rgba(0,0,0,0.06)_1px,transparent_1px),linear-gradient(90deg,rgba(0,0,0,0.06)_1px,transparent_1px)] bg-[size:48px_48px]"></div>
	  <!-- Grid background: darker circle around mouse (masked) -->
	<div id="hero-grid-dark" class="absolute inset-0 pointer-events-none" style="background-size:48px 48px; background-image: linear-gradient(rgba(0,0,0,0.18) 1px, transparent 1px), linear-gradient(90deg, rgba(0,0,0,0.18) 1px, transparent 1px);"></div>
	  <!-- Radial glow -->
	  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[700px] bg-[#ec3750]/5 rounded-full blur-[140px] pointer-events-none"></div>
	  <!-- Bottom fade -->
	  <div class="absolute bottom-0 inset-x-0 h-32 bg-gradient-to-t from-white to-transparent pointer-events-none"></div>

	  <div class="relative z-10 flex flex-col items-center gap-8 max-w-3xl">

        <!-- Logo -->
        <Image
          src={logosvg}
          alt="Pocketmod"
          class="[transform:perspective()_rotateY(0deg)] hover:[transform:perspective()_rotateY(-12deg)] duration-300 hover:scale-[0.98] transition-transform"
        />
		
        <!-- CTAs -->
        <div class="flex gap-4 flex-wrap justify-center">
			<a
            href="/back"
            class="text-zinc-800 hover:text-black border border-zinc-700 hover:border-zinc-500 px-10 py-4 rounded-2xl font-semibold transition-all"
          >Get started</a>
          <button
            id="hero-rsvp"
            class="bg-[#ec3750] hover:bg-[#d42f45] text-white font-black text-lg px-10 py-4 rounded-2xl transition-all hover:scale-105 hover:shadow-[0_0_40px_rgba(236,55,80,0.45)] cursor-pointer"
          >RSVP</button>
          <a
            href="/back#gallery"
            class="text-zinc-800 hover:text-black border border-zinc-700 hover:border-zinc-500 px-10 py-4 rounded-2xl font-semibold transition-all"
          >Gallery</a>
          <a
            href="/back#shop"
            class="text-zinc-800 hover:text-black border border-zinc-700 hover:border-zinc-500 px-10 py-4 rounded-2xl font-semibold transition-all"
          >Shop</a>
        </div>
      </div>

	  <div class="relative z-10 max-w-2xl mx-auto flex flex-col items-center gap-6 mt-20">
          <h2 class="text-3xl font-black text-center">
            <a href="/back#introduction" class="text-black transition-colors">
              Learn more
            </a>
          </h2>
        <div class="w-full rounded-3xl overflow-hidden shadow-[0_0_60px_rgba(0,0,0,0.8)] border border-white/5">
          <mux-player
            playback-id="EcHgOK9coz5K4rjSwOkoE7Y7O01201YMIC200RI6lNxnhs"
            metadata-video-title="Intro to Pocketmod"
            metadata-viewer-user-id="user-id-007"
            style="width: 100%; --seek-backward-button: none; --seek-forward-button: none; accent-color: #ec3750;"
            poster=""
          ></mux-player>
        </div>
      </div>

      <!-- Scroll hint -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-zinc-600 text-xs flex flex-col items-center gap-1 animate-bounce">
        
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
        </svg>
      </div>
    </section>
    
    <section class="py-15 px-6 bg-zinc-950 text-white">
      <div class="max-w-2xl mx-auto">
      <h2 class="text-5xl font-black text-center mb-16">What is a Pocketmod?</h2>
      <div class="border-l-4 border-[#ec3750] pl-6 py-4">
        <p class="text-zinc-400 leading-relaxed text-lg text-center italic">A tiny gadget that plugs into your Computer. It can be anything — a keyboard light, a wireless dongle, a rage quit button, or something completely new. The only requirement is that it plugs directly into a USB port</p>
      </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════ HOW IT WORKS -->
    <section class="py-28 px-6 bg-white">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-5xl font-black mb-3">How it works</h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4">

          <!-- Step 1 -->
          <div class="bg-zinc-950 text-white rounded-3xl p-8 relative overflow-hidden group cursor-default hover:scale-[1.02] transition-transform">
            <div class="absolute -top-2 -right-2 text-[9rem] font-black leading-none text-white/[0.04] group-hover:text-white/[0.07] transition-colors select-none">01</div>
            <div class="w-64 h-64 bg-[#ec3750] rounded-2xl flex items-center justify-center mb-6 text-2xl">
				<Image src={pcbdesign} alt="Logo" class="" />
			</div>
            <h3 class="text-2xl font-black mb-3">Design your PCB</h3>
            <p class="text-zinc-400 leading-relaxed text-sm">Use KiCad, EasyEDA, or any PCB tool. Your dongle must plug directly into a USB port and do something useful — or hilariously useless :D</p>
          </div>

          <!-- Step 2 -->
          <div class="bg-zinc-100 rounded-3xl p-8 relative overflow-hidden group cursor-default hover:scale-[1.02] transition-transform">
            <div class="absolute -top-2 -right-2 text-[9rem] font-black leading-none text-zinc-900/[0.04] group-hover:text-zinc-900/[0.08] transition-colors select-none">02</div>
            <div class="w-64 h-64 bg-zinc-900 rounded-2xl flex items-center justify-center mb-6 text-2xl shadow-zinc-900/20">
              <Image src={timetracking} alt="Time Tracking" class="" />
            </div>
            <h3 class="text-2xl font-black mb-3">Track your time</h3>
            <p class="text-zinc-500 leading-relaxed text-sm">Log sessions with Lapse + a short journal entry every 3 hours of PCB work. Using programmable parts? Track your coding hours via Hackatime.</p>
          </div>

          <!-- Step 3 -->
          <div class="bg-[#ec3750] text-white rounded-3xl p-8 relative overflow-hidden group cursor-default hover:scale-[1.02] transition-transform">
            <div class="absolute -top-2 -right-2 text-[9rem] font-black leading-none text-white/10 group-hover:text-white/20 transition-colors select-none">03</div>
            <div class="w-64 h-64 bg-white/0 rounded-2xl flex items-center justify-center mb-6 text-2xl shadow-zinc-900/20">
              <Image src={grantcard} alt="Grant Card" class="" />
            </div>
            <h3 class="text-2xl font-black mb-3">Get your grant</h3>
            <p class="text-white/80 leading-relaxed text-sm">Submit your design and receive a grant (4.5$/h) to get it manufactured plus parts and printing.</p>
          </div>

          <!-- Step 4 -->
          <div class="bg-zinc-950 text-white rounded-3xl p-8 relative overflow-hidden group cursor-default hover:scale-[1.02] transition-transform">
            <div class="absolute -top-2 -right-2 text-[9rem] font-black leading-none text-white/[0.04] group-hover:text-white/[0.07] transition-colors select-none">04</div>
            <div class="w-64 h-64 bg-zinc-900 rounded-2xl flex items-center justify-center mb-6 text-2xl">
              <Image src={prizesimg} alt="Prizes" class="" />
            </div>
            <h3 class="text-2xl font-black mb-3">Earn free stuff</h3>
            <p class="text-zinc-400 leading-relaxed text-sm">Upload a short clip of your gadget working. Convert remaining grant balance into "sticks" (1$ = 1 stick) and get prizes from the shop.</p>
          </div>

        </div>
      </div>
    </section>

	<!-- ═══════════════════════════════════════════════════ GALLERY PREVIEW -->
    <section class="py-28 px-6 bg-white">
      <div class="max-w-4xl mx-auto">
        <div class="flex justify-between items-end mb-10">
          <div>
            <h2 class="text-5xl font-black">Gallery</h2>
            <p class="text-zinc-500 mt-2">What others have built</p>
          </div>
          <a href="/back#gallery" class="text-[#ec3750] font-bold hover:underline underline-offset-4">See all →</a>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
          {[1, 2, 3].map(() => (
            <GalleryCard title="Keyboard light" description="A simple board with LEDs" image="https://cdn.hackclub.com/019d77c9-a8f9-7011-a5a0-f9d1d2f8488e/paste-1775831196488.png" maker="@leost" pcbViewerUrl="https://user-cdn.hackclub-assets.com/019d839c-a218-7969-8cda-e0e9103752f4/flagship_pcb.pdf" schematicsUrl="https://user-cdn.hackclub-assets.com/019d83b0-18dd-778b-a692-728647b747dd/intro_to_pcb_design.pdf"/>
            <GalleryCard title="Stats viewer" description="A pocketmod that visualizes your CPU and RAM usage as little pixel animal. Based on the RP2354. Note: WIP" image="https://user-cdn.hackclub-assets.com/019d838d-a263-7dc0-b21c-1a817d57cdf1/Bildschirmfoto%20vom%202026-04-12%2023-15-38.png" maker="@leost" pcbViewerUrl="https://user-cdn.hackclub-assets.com/019d839c-a218-7969-8cda-e0e9103752f4/flagship_pcb.pdf" schematicsUrl="https://user-cdn.hackclub-assets.com/019d839c-a218-7969-8cda-e0e9103752f4/flagship_schematics.pdf" />
          ))}
        </div>
      </div>

	  <div class="max-w-2xl mx-auto flex flex-col items-center gap-6 text-center mt-20 bg-rose-300 rounded-3xl p-10">
        <h2 class="text-5xl font-black text-zine-600">What could you build?</h2>
        <p class="text-zinc-600 text-lg">Basically anything that plugs into USB. Need some inspiration?</p>
        <Generator />
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════ FAQ -->
    <section class="py-15 px-6 bg-zinc-950 text-white">
      <div class="max-w-2xl mx-auto">
        <h2 class="text-5xl font-black text-center mb-16">FAQ</h2>
        <div class="flex flex-col divide-y divide-zinc-800">
          {[
            {
              q: "How does the grant work?",
              a: "After you submit your finished design, you receive a manufacturing grant of ~$4.5 per tracked hour as a HCB card. Use it at PCB vendors like JLCPCB or PCBWay, part suppliers, or #printing-league to get your pocketmod built.",
            },
            {
              q: "What if I've never designed a PCB before?",
              a: "That's exactly who this is for. We have beginner guides for PCB design from scratch, plus intermediate tutorials for specific topics like designing an RP2350 board. The community and help channels are there for any questions.",
            },
            {
              q: "How do I track my time?",
              a: "For PCB design: Lapse + a short journal entry after every session or 3 hours. For programming (if your dongle has a microcontroller): Hackatime. Both count toward your grant.",
            },
            {
              q: "Does my dongle need to be programmable?",
              a: "Nope! A desk light, USB hub, or a button array is totally valid. If your design does include a programmable chip (RP2040, ESP32, etc.), you'll also need firmware to go with it.",
            },
            {
              q: "How long does the program run?",
              a: "This is currently a draft, RSVP to get notified when it launches.",
            },
            {
              q: "What prizes can I get?",
              a: "After uploading a working clip of your gadget, convert your remaining grant balance into sticks (1$ = 1 stick). Sticks are redeemable for prizes in the Hack Club shop.",
            },
            {
              q: "Is this legit?",
              a: "Yes — ",
            },
            {
              q: "My question isn't covered here",
              a: "Join the #pocketmod channel on the Hack Club Slack or DM @leost",
            },
          ].map(({ q, a }) => (
            <details class="group py-5 cursor-pointer">
              <summary class="list-none flex items-start justify-between gap-4 font-semibold text-lg">
                <span>{q}</span>
                <svg
                  class="w-5 h-5 text-zinc-500 shrink-0 mt-1 group-open:rotate-180 transition-transform"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <p class="mt-3 text-zinc-400 leading-relaxed text-sm">{a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <ProjectPopup title="" description="" maker="" images={[]} />

    <!-- Footer -->
    <footer class="py-8 px-6 bg-zinc-950 text-center text-zinc-600 text-sm">
      Made with <span class="text-[#ec3750]">♥</span> by @leost ·
      Hopefully soon @<a href="https://hackclub.com" class="hover:text-zinc-400 transition-colors underline underline-offset-2">Hack Club</a> HQ ;)
    </footer>

    <!-- Hidden fillout trigger (injected by fillout.com script) -->
    <div
      class="absolute -left-[9999px] -top-[9999px] w-0 h-0 overflow-hidden"
      id="fillout-wrapper"
    >
      <div
        data-fillout-id="6AHbFZiJBVus"
        data-fillout-embed-type="popup"
        data-fillout-button-text="Sign up"
        data-fillout-dynamic-resize
        data-fillout-button-color="#ec3750"
        data-fillout-button-size="medium"
        data-fillout-inherit-parameters
        data-fillout-popup-size="medium"
      ></div>
    </div>

  </body>
</html>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // ── Fillout popup trigger ──────────────────────────────
    const triggerFillout = () => {
      const btn = document.querySelector("#fillout-wrapper button") as HTMLButtonElement | null;
      btn?.click();
    };
    document.getElementById("hero-rsvp")?.addEventListener("click", triggerFillout);
    document.getElementById("nav-rsvp")?.addEventListener("click", triggerFillout);
    document.getElementById("footer-rsvp")?.addEventListener("click", triggerFillout);

    // ── Darker grid circle around mouse ───────────────────
    const darkGrid = document.getElementById("hero-grid-dark");
    const hero     = document.getElementById("hero-section");
    if (!darkGrid || !hero) return;

    const D: HTMLElement = darkGrid;
    const RADIUS = 160;

    let mx = -9999, my = -9999;

    hero.addEventListener("mousemove", (e: MouseEvent) => {
      const rect = hero.getBoundingClientRect();
      mx = e.clientX - rect.left;
      my = e.clientY - rect.top;
      D.style.maskImage = `radial-gradient(circle ${RADIUS}px at ${mx}px ${my}px, black 0%, transparent 100%)`;
    });

    hero.addEventListener("mouseleave", () => {
      D.style.maskImage = `radial-gradient(circle 0px at -9999px -9999px, black 0%, transparent 0%)`;
    });

    D.style.maskImage = `radial-gradient(circle 0px at -9999px -9999px, black 0%, transparent 0%)`;
  });
</script>
